    "value_loss_coef": 0.5,
    "max_grad_norm": 0.5,
    "use_clipped_value_loss": true,
    "use_linear_lr_decay": false,
    "lr_decay_ratio": 1.0,
    "use_gae": true,
    "gae_lambda": 0.95,
    "max_episode_steps": 500,
    "init_w_sampling": "uniform",
    "seed": 1
}