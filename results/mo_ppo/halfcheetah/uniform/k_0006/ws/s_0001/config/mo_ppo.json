{
    "num_subproblems": 6,
    "num_processes": 8,
    "archive_size": null,
    "num_steps": 512,
    "gamma": 0.995,
    "obj_rms": true,
    "ob_rms": true,
    "use_proper_time_limits": true,
    "net_arch": [
        64,
        64
    ],
    "layernorm": false,
    "learning_rate": 0.0003,
    "eps": 1e-05,
